# Optional environment variables for local development.
# This public repository does not ship with any built-in API key.
#
# PDF -> Word support:
# Point this to your local Offline_PDF_Structure folder if you want
# scanned-PDF OCR, table recognition, and direct PDF-to-DOCX export.
DOCUGEN_OFFLINE_PDF_ROOT=D:\path\to\Offline_PDF_Structure

# Optional proxy settings when your model endpoint or Google-compatible
# endpoint requires a local proxy.
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
